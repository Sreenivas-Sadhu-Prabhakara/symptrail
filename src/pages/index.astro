---
const base = import.meta.env.BASE_URL;
// Trailing-slash-safe asset helper: BASE_URL is "/symptrail/" in build.
const asset = (p) => base.replace(/\/$/, '') + '/' + p.replace(/^\//, '');
const title = 'symptrail — Private Symptom Tracker & Journal for Doctors';
const description =
  'Free, private symptom tracker. Log symptoms, severity and triggers, spot trends, and print a clean report for your doctor. Data never leaves your device.';
const site = Astro.site ?? new URL('https://sreenivas-sadhu-prabhakara.github.io');
// Directory URL: keep the trailing slash so canonical, og:url, sitemap and manifest all agree.
const canonical = new URL(base.endsWith('/') ? base : base + '/', site).href;
const ogImage = new URL(asset('og.png'), site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      name: 'symptrail',
      url: canonical,
      applicationCategory: 'HealthApplication',
      operatingSystem: 'Any (web browser)',
      browserRequirements: 'Requires JavaScript and a modern browser.',
      description:
        'A private, offline symptom journal. Log symptoms, severity and triggers, view trends, and print a doctor-ready report. All data is stored only in your browser and never leaves your device.',
      image: ogImage,
      isAccessibleForFree: true,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      featureList: [
        'Log symptoms with 0–10 severity, duration, body area, triggers and medications',
        'Chronological timeline grouped by day',
        'Severity trends charted per symptom, drawn entirely client-side',
        'Printable doctor’s report for any date range (Save as PDF)',
        'JSON backup export and import',
        'Works fully offline; data stored only in the browser',
      ],
      permissions: 'No network access; no account required.',
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'Is symptrail a free symptom tracker I can use without an account?',
          acceptedAnswer: {
            '@type': 'Answer',
            text:
              'Yes. symptrail is completely free with no sign-up. There is no account and no server — you just open the page and start logging. Your entries are saved in your own browser using localStorage.',
          },
        },
        {
          '@type': 'Question',
          name: 'Where is my symptom data stored, and is it private?',
          acceptedAnswer: {
            '@type': 'Answer',
            text:
              'Everything is stored only in your browser with localStorage. There is no back end, and the page ships a strict Content-Security-Policy that blocks all outbound network connections (connect-src ’none’), so your health data physically cannot leave the device.',
          },
        },
        {
          '@type': 'Question',
          name: 'How do I make a symptom report to give my doctor?',
          acceptedAnswer: {
            '@type': 'Answer',
            text:
              'Choose “Report for doctor”, pick a date range, then print. Select “Save as PDF” in the print dialog to get a clean file. The report shows a summary table — occurrences, average and peak severity, and last seen per symptom — followed by every entry in order.',
          },
        },
        {
          '@type': 'Question',
          name: 'Does the symptom tracker work offline?',
          acceptedAnswer: {
            '@type': 'Answer',
            text:
              'Yes. Once the page has loaded it needs no connection at all. You can add entries, view trends and generate reports fully offline, on a plane or with no signal.',
          },
        },
        {
          '@type': 'Question',
          name: 'What do the 0–10 severity ratings mean?',
          acceptedAnswer: {
            '@type': 'Answer',
            text:
              'Severity is your own 0–10 rating where 0 is “none” and 10 is the worst you can imagine. It is subjective by design — it captures how you experienced each episode, which is what is useful to track over time and discuss with a clinician.',
          },
        },
        {
          '@type': 'Question',
          name: 'Can I back up my symptom log or move it to another device?',
          acceptedAnswer: {
            '@type': 'Answer',
            text:
              'Yes. Use “Export backup (JSON)” to save a file, then “Import backup” in another browser or device to restore it. Because data lives only in one browser, the backup export is how you keep it safe or transfer it.',
          },
        },
      ],
    },
  ],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'none'; base-uri 'self'; form-action 'none'; object-src 'none'"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="symptom tracker, symptom journal, symptom diary for doctor, private offline symptom log, symptom diary, health log, symptom record"
    />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#2e7d74" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={asset('favicon.svg')} />
    <link rel="icon" href={asset('favicon.ico')} sizes="any" />
    <link rel="apple-touch-icon" href={asset('apple-touch-icon.png')} />
    <link rel="manifest" href={asset('manifest.webmanifest')} />
    <link rel="stylesheet" href={asset('styles.css')} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="symptrail" />
    <meta property="og:title" content="symptrail — private symptom tracker & journal for your doctor" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="symptrail — a private, offline symptom journal that prints a report for your doctor" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="symptrail — private symptom tracker & journal for your doctor" />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="symptrail — a private, offline symptom journal that prints a report for your doctor" />
    <meta name="generator" content={Astro.generator} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a class="skip" href="#quickadd">Skip to add an entry</a>
    <span id="live" class="sr-only" role="status" aria-live="polite"></span>

    <!-- ============ privacy banner ============ -->
    <div class="privacy">
      <div class="privacy-inner">
        <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
          <path d="M9 12l2 2 4-4" />
        </svg>
        <span><strong>Your health data never leaves this device.</strong> <span class="thin">No account, no servers, no tracking — everything is stored only in this browser.</span></span>
      </div>
    </div>

    <!-- ============ masthead ============ -->
    <header class="masthead">
      <div class="masthead-inner">
        <div class="brand">
          <svg class="brand-mark" viewBox="0 0 40 40" aria-hidden="true" fill="none">
            <line x1="8" y1="4" x2="8" y2="36" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
            <circle cx="8" cy="10" r="3.4" fill="currentColor" />
            <circle cx="8" cy="21" r="4.6" fill="currentColor" />
            <circle cx="8" cy="32" r="2.6" fill="currentColor" />
            <path d="M17 21h6l2.5-6 3.5 12 2.5-6h4" stroke="#c4694a" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
          </svg>
          <div>
            <p class="brand-name"><b>sympt</b>rail</p>
            <p class="brand-tag">Private symptom journal</p>
          </div>
        </div>
        <div class="mast-actions">
          <button type="button" id="toggle-bigtext" class="btn btn-sm toggle" aria-pressed="false">
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7V5h16v2" /><path d="M9 20h6" /><path d="M12 5v15" /></svg>
            Larger text
          </button>
          <button type="button" id="open-report" class="btn btn-sm btn-primary">
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9V4h9l3 3v2" /><path d="M6 18h12" /><rect x="6" y="13" width="12" height="8" rx="1" /><path d="M6 9h12" /></svg>
            Report for doctor
          </button>
        </div>
      </div>
    </header>

    <!-- ============ intro ============ -->
    <section class="intro">
      <h1>Keep a symptom diary you can actually <span class="accent">hand your doctor</span>.</h1>
      <p class="lede">
        Log what you feel, how bad it is, and what might have triggered it. symptrail turns the
        running log into a clean, printable summary — occurrences, average and peak severity,
        and every entry in order. Private and offline by design.
      </p>
    </section>

    <!-- ============ main ============ -->
    <main class="main" id="main">
      <div class="grid">
        <!-- ---- quick add column ---- -->
        <section class="col-add" aria-labelledby="qa-h">
          <div class="panel panel-pad">
            <h2 class="panel-h" id="qa-h">Add an entry</h2>
            <form id="quickadd" class="qa-form" novalidate>
              <div class="field field-datetime">
                <span class="lbl" id="dt-lbl">When</span>
                <div class="row2" role="group" aria-labelledby="dt-lbl">
                  <div class="field">
                    <label for="f-date" class="sr-only">Date</label>
                    <input type="date" id="f-date" name="date" autocomplete="off" />
                  </div>
                  <div class="field">
                    <label for="f-time" class="sr-only">Time</label>
                    <input type="time" id="f-time" name="time" autocomplete="off" />
                  </div>
                  <button type="button" id="f-now" class="btn btn-sm now-btn">Now</button>
                </div>
              </div>

              <div class="field">
                <label for="f-symptom">Symptom(s) <span class="hint">comma-separated</span></label>
                <input type="text" id="f-symptom" name="symptom" placeholder="e.g. Headache, Nausea" autocomplete="off" autocapitalize="sentences" />
                <div class="chips" id="recent-chips" hidden></div>
              </div>

              <div class="field sev-field">
                <div class="sev-top">
                  <span class="lbl" id="sev-lbl">Severity</span>
                  <span class="sev-readout" aria-hidden="true">
                    <output id="f-sev-out" class="num" for="f-severity">3</output>
                    <span class="sev-word">mild</span>
                  </span>
                </div>
                <input type="range" id="f-severity" name="severity" min="0" max="10" step="1" value="3" aria-labelledby="sev-lbl" aria-describedby="sev-help" />
                <div class="sev-scale-marks" aria-hidden="true"><span>0 none</span><span>5</span><span>10 worst</span></div>
                <span id="sev-help" class="sr-only">Rate this symptom from 0, none, to 10, worst imaginable.</span>
              </div>

              <div class="row2">
                <div class="field">
                  <label for="f-duration">Duration <span class="hint">optional</span></label>
                  <input type="text" id="f-duration" name="duration" placeholder="e.g. 2 hours" autocomplete="off" />
                </div>
                <div class="field">
                  <label for="f-area">Body area <span class="hint">optional</span></label>
                  <input type="text" id="f-area" name="area" placeholder="e.g. left temple" autocomplete="off" />
                </div>
              </div>

              <div class="field">
                <label for="f-tags">Triggers &amp; meds <span class="hint">tags, comma-separated</span></label>
                <input type="text" id="f-tags" name="tags" placeholder="e.g. poor sleep, ibuprofen" autocomplete="off" />
              </div>

              <div class="field">
                <label for="f-notes">Notes <span class="hint">optional</span></label>
                <textarea id="f-notes" name="notes" placeholder="Anything else worth remembering."></textarea>
              </div>

              <div class="qa-submit">
                <button type="submit" class="btn btn-primary btn-block">
                  <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14" /></svg>
                  Save entry
                </button>
              </div>
            </form>
          </div>
        </section>

        <!-- ---- workspace column ---- -->
        <section class="col-view" aria-label="Your log">
          <!-- empty state -->
          <div id="empty" class="empty">
            <div class="empty-card">
              <span class="empty-spine" aria-hidden="true"></span>
              <h2>Your journal is empty — start with today.</h2>
              <p>
                Add your first entry on the left, or load a set of example entries to see how the
                timeline, trends and doctor's report work. You can clear the examples anytime.
              </p>
              <div class="empty-actions">
                <button type="button" id="load-examples" class="btn btn-primary">Load example entries</button>
                <a class="btn btn-ghost" href="#quickadd">Add my first entry</a>
              </div>
              <p class="empty-note">Examples are stored only in this browser and can be removed with “Delete everything”.</p>
            </div>
          </div>

          <!-- workspace (shown when there is data) -->
          <div id="workspace" hidden>
            <div class="stats" id="stats" hidden></div>

            <div class="workspace-top">
              <div class="tabs" id="viewtabs" role="tablist" aria-label="Log views">
                <button type="button" class="tab" id="tab-timeline" role="tab" aria-selected="true" aria-controls="panel-timeline">Timeline</button>
                <button type="button" class="tab" id="tab-trends" role="tab" aria-selected="false" aria-controls="panel-trends" tabindex="-1">Trends</button>
              </div>
            </div>

            <div class="panel filters" role="group" aria-label="Filter entries">
              <div class="field filter-item">
                <label for="filter-symptom">Symptom</label>
                <select id="filter-symptom"><option value="">All symptoms</option></select>
              </div>
              <div class="field filter-item">
                <label for="filter-tag">Tag</label>
                <select id="filter-tag"><option value="">All tags</option></select>
              </div>
              <div class="field filter-item narrow">
                <label for="filter-from">From</label>
                <input type="date" id="filter-from" />
              </div>
              <div class="field filter-item narrow">
                <label for="filter-to">To</label>
                <input type="date" id="filter-to" />
              </div>
              <button type="button" id="filter-clear" class="btn btn-sm btn-ghost">Clear filters</button>
            </div>

            <div id="panel-timeline" role="tabpanel" aria-labelledby="tab-timeline">
              <ol class="timeline" id="timeline"></ol>
            </div>

            <div id="panel-trends" role="tabpanel" aria-labelledby="tab-trends" hidden>
              <div id="trends"></div>
            </div>
          </div>
        </section>
      </div>

      <!-- ============ data management ============ -->
      <section class="panel panel-pad data-panel" aria-labelledby="data-h">
        <h2 class="panel-h" id="data-h">Your data &amp; backups</h2>
        <div class="data-grid">
          <div class="data-block">
            <h3>Back up or move your log</h3>
            <p>Everything lives in this browser only. Export a JSON file to keep a backup or move it to another device, then import it there.</p>
            <div class="data-actions">
              <button type="button" id="export-json" class="btn">
                <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12" /><path d="M8 11l4 4 4-4" /><path d="M5 21h14" /></svg>
                Export backup (JSON)
              </button>
              <label class="file-label">
                <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15V3" /><path d="M8 7l4-4 4 4" /><path d="M5 21h14" /></svg>
                Import backup
                <input type="file" id="import-json" accept="application/json,.json" />
              </label>
            </div>
          </div>
          <div class="data-block">
            <h3>Start over</h3>
            <p>This permanently erases every entry stored in this browser. There is no undo, so export a backup first if you might want it.</p>
            <div class="data-actions">
              <button type="button" id="delete-all" class="btn btn-danger">
                <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7h16" /><path d="M9 7V4h6v3" /><path d="M6 7l1 13h10l1-13" /></svg>
                Delete everything
              </button>
              <button type="button" id="load-examples-2" class="btn btn-ghost btn-sm">Load example entries</button>
            </div>
          </div>
        </div>

        <div class="privacy-explain">
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="4" y="10" width="16" height="11" rx="2" /><path d="M8 10V7a4 4 0 0 1 8 0v3" />
          </svg>
          <div>
            <h3>Why this is genuinely private</h3>
            <p>
              symptrail has no back end. Your entries are saved with your browser's
              <code>localStorage</code> and never sent anywhere. The page even blocks all outbound
              network connections with a strict Content-Security-Policy
              (<code>connect-src 'none'</code>), so your health information physically cannot leave
              this device. Clearing this browser's data, or a different browser or device, means a
              fresh, empty log — which is why the backup export exists.
            </p>
          </div>
        </div>
      </section>

      <!-- ============ FAQ ============ -->
      <section class="faq" aria-labelledby="faq-h">
        <h2 id="faq-h">Questions</h2>
        <p class="faq-sub">The short version: it's a private symptom diary that prints a report for your doctor.</p>

        <details>
          <summary>Is symptrail a free symptom tracker I can use without an account?</summary>
          <div class="faq-a">
            <p>Yes. symptrail is completely free with no sign-up. There is no account and no server — you just open the page and start logging. Your entries are saved in your own browser using <code>localStorage</code>.</p>
          </div>
        </details>
        <details>
          <summary>Where is my symptom data stored, and is it private?</summary>
          <div class="faq-a">
            <p>Everything is stored only in your browser with <code>localStorage</code>. There is no back end, and the page ships a strict Content-Security-Policy that blocks all outbound network connections (<code>connect-src 'none'</code>), so your health data physically cannot leave the device.</p>
          </div>
        </details>
        <details>
          <summary>How do I make a symptom report to give my doctor?</summary>
          <div class="faq-a">
            <p>Choose <strong>Report for doctor</strong>, pick a date range, then print. Select “Save as PDF” in the print dialog to get a clean file. The report shows a summary table — occurrences, average and peak severity, and last seen per symptom — followed by every entry in order.</p>
          </div>
        </details>
        <details>
          <summary>Does the symptom tracker work offline?</summary>
          <div class="faq-a">
            <p>Yes. Once the page has loaded it needs no connection at all. You can add entries, view trends and generate reports fully offline, on a plane or with no signal.</p>
          </div>
        </details>
        <details>
          <summary>What do the 0–10 severity ratings mean?</summary>
          <div class="faq-a">
            <p>Severity is your own 0–10 rating, where 0 is “none” and 10 is the worst you can imagine. It's subjective by design — it captures how <em>you</em> experienced each episode, which is exactly what's useful to track over time and discuss with a clinician.</p>
          </div>
        </details>
        <details>
          <summary>Can I back up my symptom log or move it to another device?</summary>
          <div class="faq-a">
            <p>Yes. Use <strong>Export backup (JSON)</strong> to save a file, then <strong>Import backup</strong> in another browser or device to restore it. Because data lives only in one browser, the backup export is how you keep it safe or transfer it.</p>
          </div>
        </details>
      </section>
    </main>

    <!-- ============ report modal ============ -->
    <div id="report-modal" class="modal" role="dialog" aria-modal="true" aria-labelledby="report-title" hidden>
      <div class="modal-panel">
        <div class="modal-bar">
          <div class="modal-range">
            <h2 id="report-title">Doctor's report</h2>
            <div class="field">
              <label for="r-from">From</label>
              <input type="date" id="r-from" />
            </div>
            <div class="field">
              <label for="r-to">To</label>
              <input type="date" id="r-to" />
            </div>
          </div>
          <div class="modal-actions">
            <button type="button" id="report-print" class="btn btn-primary btn-sm">
              <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9V3h12v6" /><rect x="4" y="9" width="16" height="8" rx="1" /><path d="M8 17h8v4H8z" /></svg>
              Print / Save as PDF
            </button>
            <button type="button" id="report-close" class="btn btn-ghost btn-sm">Close</button>
          </div>
        </div>
        <div class="report-scroll">
          <div class="report-sheet" id="report"></div>
        </div>
      </div>
    </div>

    <!-- ============ footer / disclaimer ============ -->
    <footer class="footer">
      <div class="footer-inner">
        <p class="disclaimer">
          <strong>Medical disclaimer.</strong> symptrail is a personal record-keeping tool, not
          medical advice and not a diagnostic device. It cannot diagnose, treat, or prevent any
          condition. Nothing here is a substitute for professional judgement — always consult a
          qualified health professional about your symptoms, and seek urgent care for anything
          severe or worsening. The authors accept no liability for decisions made using this tool.
        </p>
        <div class="footer-meta">
          <span>symptrail — a private symptom journal</span>
          <span class="footer-dot" aria-hidden="true">•</span>
          <span>100% offline · stored only on this device</span>
          <span class="footer-dot" aria-hidden="true">•</span>
          <a href="#main">Back to top</a>
        </div>
      </div>
    </footer>

    <script src={asset('app.js')} defer></script>
  </body>
</html>
